Cell[BoxData[{
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"PPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Se", " ", "v"}], 
        RowBox[{
         RowBox[{"Se", " ", "v"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "Sp"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "v"}], ")"}]}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"NPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Sp", "(", 
         RowBox[{"1", "-", "v"}], ")"}], 
        RowBox[{
         RowBox[{"Sp", "(", 
          RowBox[{"1", "-", "v"}], ")"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "Se"}], ")"}], "v"}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"OR", "=", 
      StyleBox[
       RowBox[{
        FractionBox["Se", 
         RowBox[{"1", "-", "Se", " "}]], "/", 
        FractionBox[
         RowBox[{"1", "-", "Sp"}], "Sp"]}],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{
      RowBox[{"LR", "+"}], " ", "=", 
      StyleBox[
