Cell[CellGroupData[{

Cell["Details", "Section",
 Editable->False,
 CellChangeTimes->{{3.8242770577803974`*^9, 3.82427706282949*^9}},
 CellTags->"Details",ExpressionUUID->"41027857-eac7-45d2-a2ad-72b2955da2a3"],

Cell[TextData[{
 "These diagnostic accuracy measures of a diagnostic test applied to a \
diseased and a nondiseased populations can be calculated as functions of the \
test sensitivity and specificity. Sensitivity is the fraction of the diseased \
population with a positive test result, while specificity is the fraction of \
the nondiseased population with a negative test result.  If we denote by ",
 Cell[BoxData[
  FormBox["Se", TraditionalForm]], "InlineMath",ExpressionUUID->
  "a17568bd-3a57-44b8-91f7-5ac3af4a4232"],
 " the sensitivity",
 StyleBox[",",
  FontSize->11],
 " ",
 Cell[BoxData[
  FormBox["Sp", TraditionalForm]], "InlineMath",ExpressionUUID->
  "d3f1cec0-0605-408c-bd73-8bfb7653c19f"],
 " the specificity and ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]], "InlineMath",ExpressionUUID->
  "386c63c2-de90-477a-afcb-734e10a817c8"],
 " the prevalence, we have: "
}], "Text",
 Editable->False,
 CellChangeTimes->{
  3.6462972184250193`*^9, {3.646299017067019*^9, 3.646299034809018*^9}, {
   3.6464175360817204`*^9, 3.646417617296505*^9}, {3.646503135886409*^9, 
   3.646503162726223*^9}, {3.646503204507545*^9, 3.6465032210780993`*^9}, 
   3.646503453674555*^9, {3.646590274420603*^9, 3.646590286439289*^9}, {
   3.731411654376609*^9, 3.731411660320647*^9}, 3.731412014152563*^9, 
   3.731586726454618*^9, {3.73158675755149*^9, 3.731586818534366*^9}, 
   3.731993705771762*^9, 3.732381739432839*^9, {3.732546557399947*^9, 
   3.732546581142947*^9}, {3.988504156626562*^9, 3.988504194571398*^9}, 
   3.988506103686661*^9},
 CellID->2279429,ExpressionUUID->"1ce3c58a-ca96-4cc2-b976-5b5fd522e4fe"],

Cell[BoxData[{
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"PPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Se", " ", "v"}], 
        RowBox[{
         RowBox[{"Se", " ", "v"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "Sp"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "v"}], ")"}]}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"NPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Sp", "(", 
         RowBox[{"1", "-", "v"}], ")"}], 
        RowBox[{
         RowBox[{"Sp", "(", 
          RowBox[{"1", "-", "v"}], ")"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "Se"}], ")"}], "v"}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"OR", "=", 
      StyleBox[
       RowBox[{
        FractionBox["Se", 
         RowBox[{"1", "-", "Se", " "}]], "/", 
        FractionBox[
         RowBox[{"1", "-", "Sp"}], "Sp"]}],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{
      RowBox[{"LR", "+"}], " ", "=", 
      StyleBox[
       FractionBox[
        RowBox[{
         StyleBox["Se",
          FontFamily->"Source Sans Pro",
          FontWeight->"Normal"], 
         StyleBox[
          RowBox[{
           StyleBox[" ",
            FontFamily->"Source Sans Pro",
            FontWeight->"Normal"], 
           StyleBox[" ",
            FontFamily->"Times New Roman"]}]]}], 
        RowBox[{"1", "-", "Sp"}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{"LR", "-"}], " ", "=", 
    StyleBox[
     FractionBox[
      RowBox[{"1", "-", "Se"}], "Sp"],
     FontSize->16]}], "Text",
   FontWeight->"Plain"], TraditionalForm]}], "Input",
 Editable->False,
 Evaluatable->False,
 CellChangeTimes->{{3.9884945847585335`*^9, 3.9884945847585335`*^9}, {
   3.988494639182228*^9, 3.9884946682540665`*^9}, 3.988494715574869*^9, 
   3.9884952223272247`*^9, {3.988495268119255*^9, 3.988495353175894*^9}, {
   3.9884954060552425`*^9, 3.988495413494894*^9}, {3.9885018511864853`*^9, 
   3.9885018669034157`*^9}},ExpressionUUID->"5158753f-f40e-984a-baed-\
758214b21f11"],

Cell["\<\
Given diseased and a nondiseased populations, the specificity can be defined \
as a function of sensitivity; therefore, parametric plots of any pair of the \
diagnostic accuracy measures can be generated .
To the best of our knowledge, with the exception of the pair PPV and NPV [1, \
2], the relation between any other pair of the given diagnostic accuracy \
measures has not been discussed in the literature.
In the thumbnail, the population data describe a bimodal distribution of \
serum glucose measurements in nondiabetic and diabetic populations [3].
This Demonstration is an extended version of another Demonstration [2], first \
published in 2015, and is appropriate as an educational tool in medical \
statistics and as an exploratory research tool in diagnostic accuracy studies.
\
\>", "Text",
 Editable->False,
 CellChangeTimes->{{3.551267277579608*^9, 3.551267338117554*^9}, {
   3.5512721171837006`*^9, 3.5512721434967012`*^9}, {3.646417296749917*^9, 
