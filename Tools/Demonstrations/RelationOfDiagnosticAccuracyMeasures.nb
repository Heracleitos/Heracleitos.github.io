Cell[CellGroupData[{

Cell["Description", "Section",
 Editable->False,
 CellGroupingRules->{"GroupTogetherGrouping", 10001.},
 CellChangeTimes->{{3.8242782643101068`*^9, 3.824278284056035*^9}, 
