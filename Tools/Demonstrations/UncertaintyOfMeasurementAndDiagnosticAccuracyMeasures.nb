Cell[CellGroupData[{

Cell["Details", "Section",
 Editable->False,
 CellChangeTimes->{{3.8243534066574497`*^9, 3.824353415146681*^9}},
 CellTags->"Details",ExpressionUUID->"3f64f17e-6bf3-44be-8c5b-975ad3a3d8c9"],

Cell[TextData[{
 "In addition to the receiver operating characteristic (ROC) curves, various \
measures are used in the evaluation of the clinical accuracy of a diagnostic \
test applied to a diseased or a nondiseased population. They can be \
calculated versus the sensitivity or the specificity of the test. Sensitivity \
is the fraction of the diseased population with a positive test, while \
specificity is the fraction of the nondiseased population with a negative \
test. In addition, if we denote by ",
 StyleBox["v",
  FontSlant->"Italic"],
 " the prevalence of the disease, we have:"
}], "Text",
 Editable->False,
 CellChangeTimes->{
  3.729999760422978*^9, {3.730866937274197*^9, 3.730866937306204*^9}, {
   3.731164630218442*^9, 3.731164630272465*^9}, 3.824363039534446*^9, 
   3.9883682496041145`*^9, {3.988368323364271*^9, 3.988368598259905*^9}, {
   3.988368642485668*^9, 3.988368694715433*^9}, 3.9884966604155693`*^9, {
   3.9892803400594215`*^9, 3.989280342548174*^9}},
 CellID->2279429,ExpressionUUID->"85c7ae3e-4c08-4d2f-bcc7-9cf6dcb38cf9"],

Cell[BoxData[{
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"PPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Se", " ", "v"}], 
        RowBox[{
         RowBox[{"Se", " ", "v"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "Sp"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "v"}], ")"}]}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"NPV", "=", 
      StyleBox[
       FractionBox[
        RowBox[{"Sp", "(", 
         RowBox[{"1", "-", "v"}], ")"}], 
        RowBox[{
         RowBox[{"Sp", "(", 
          RowBox[{"1", "-", "v"}], ")"}], "+", 
         RowBox[{
          RowBox[{
           StyleBox["(",
            FontSize->12], 
           RowBox[{"1", "-", "Se"}], ")"}], "v"}]}]],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"OR", "=", 
      StyleBox[
       RowBox[{
        FractionBox["Se", 
         RowBox[{"1", "-", "Se", " "}]], "/", 
        FractionBox[
         RowBox[{"1", "-", "Sp"}], "Sp"]}],
       FontSize->16]}],
     FontWeight->"Plain"], 
    StyleBox[" ",
     FontSize->16,
     FontWeight->"Normal"]}], "Text"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{"LR", "+"}], " ", "=", 
    StyleBox[
     FractionBox[
      RowBox[{
       StyleBox["Se",
        FontWeight->"Normal"], 
       StyleBox[" ",
        FontFamily->"Times New Roman"]}], 
      RowBox[{"1", "-", "Sp"}]],
     FontSize->16]}], "Text",
   FontWeight->"Plain"], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
